{
  "manifest_version": 3,
  "name": "GrammarBlitz",
  "version": "1.0.0",
  "description": "Fast grammar shooter — spot wrong sentences and shoot them down",
  "permissions": ["storage", "tabs"],
  "icons": { "128": "assets/icon.png" },
  "action": {
    "default_icon": { "128": "assets/icon.png" }
  },
  "background": {
    "service_worker": "background.js"
  }
}
